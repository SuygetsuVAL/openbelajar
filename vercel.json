{
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "devCommand": "npm run dev",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@1.1.0",
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/storage(.*)",
            "dest": "/storage$1"
        },
        {
            "src": "/css(.*)",
            "dest": "/css$1"
        },
        {
            "src": "/js(.*)",
            "dest": "/js$1"
        },
        {
            "src": "/build(.*)",
            "dest": "/build$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
